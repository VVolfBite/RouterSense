#### Step 2: 提取 gate 网络权重

在 OLMoE 中，每个 MoE 层的 gate 是一个线性层（`gate.weight`），shape `[num_experts, hidden_dim]`。

```python
def extract_gate_weights(model, moe_layer_ids):
    """提取每个 MoE 层的 gate 权重矩阵。"""
    gates = {}
    for layer_id in moe_layer_ids:
        layer = model.model.layers[layer_id]
        gate = layer.mlp.gate  # OLMoE 的 gate 对象
        # gate.weight 或 gate.w 是 [num_experts, hidden_dim] 的矩阵
        weight = getattr(gate, 'weight', None) or getattr(gate, 'w', None)
        gates[layer_id] = weight.detach().float().cpu()
    return gates
```

#### Step 3: 跨层预测计算

```python
def cross_layer_predict(hidden_states, gates, moe_layer_ids, topk=8):
    """
    对每对相邻 MoE 层，用第 i 层的 hidden state 通过第 i+1 层的 gate 做预测。
    返回 prefetch accuracy 和 cosine similarity。
    """
    results = []
    for idx in range(len(moe_layer_ids) - 1):
        layer_i = moe_layer_ids[idx]
        layer_next = moe_layer_ids[idx + 1]

        gate_in_i = hidden_states[layer_i]      # [1, seq_len, hidden_dim]
        gate_in_next = hidden_states[layer_next]  # [1, seq_len, hidden_dim]

        # 1. Cosine similarity
        cos_sim = F.cosine_similarity(
            gate_in_i.squeeze(0), gate_in_next.squeeze(0), dim=-1
        )  # [seq_len]

        # 2. Cross-layer prediction: 用 layer_i 的 hidden state 过 layer_next 的 gate
        gate_weight = gates[layer_next]  # [num_experts, hidden_dim]
        predicted_logits = gate_in_i.squeeze(0) @ gate_weight.T  # [seq_len, num_experts]
        predicted_probs = F.softmax(predicted_logits, dim=-1)
        predicted_topk = torch.topk(predicted_probs, k=topk, dim=-1).indices  # [seq_len, topk]

        # 3. 实际 expert 选择（已在 trace 中）
        actual_logits = gate_in_next.squeeze(0) @ gate_weight.T
        actual_probs = F.softmax(actual_logits, dim=-1)
        actual_topk = torch.topk(actual_probs, k=topk, dim=-1).indices

        # 4. Prefetch accuracy per token
        per_token_acc = []
        for t in range(gate_in_i.shape[1]):
            overlap = len(set(predicted_topk[t].tolist()) & set(actual_topk[t].tolist()))
            per_token_acc.append(overlap / topk)

        results.append({
            "from_layer": layer_i,
            "to_layer": layer_next,
            "cosine_sim_mean": cos_sim.mean().item(),
            "cosine_sim_std": cos_sim.std().item(),
            "prefetch_accuracy_mean": sum(per_token_acc) / len(per_token_acc),
            "prefetch_accuracy_std": (sum((a - sum(per_token_acc)/len(per_token_acc))**2 for a in per_token_acc) / len(per_token_acc))**0.5,
        })
    return results
```

### 具体实现步骤

#### Step 1: 单层 LPT Greedy（复用已有，保留）

```python
def greedy_schedule_single_layer(traffic_matrix, num_gpus, gpu_earliest_start=None):
    """单层 LPT 调度，返回 (该层 makespan, 每 GPU 的完成时间)。"""
    if gpu_earliest_start is None:
        gpu_earliest_start = [0.0] * num_gpus
    chunks = []
    for i in range(num_gpus):
        for j in range(num_gpus):
            if i != j and traffic_matrix[i][j] > 0:
                chunks.append((traffic_matrix[i][j], i, j))
    chunks.sort(reverse=True)  # LPT
    gpu_available = list(gpu_earliest_start)
    for size, src, dst in chunks:
        start = max(gpu_available[src], gpu_available[dst])
        end = start + size
        gpu_available[src] = end
        gpu_available[dst] = end
    return max(gpu_available), gpu_available

def greedy_schedule_pairwise(T_L, C_L, T_next, num_gpus):
    """Pairwise Greedy: 每层独立 LPT，不知道下一层。"""
    _, gpu_after_d = greedy_schedule_single_layer(T_L, num_gpus)
    _, gpu_after_c = greedy_schedule_single_layer(C_L, num_gpus, gpu_after_d)
    makespan, _ = greedy_schedule_single_layer(T_next, num_gpus, gpu_after_c)
    return makespan
```

