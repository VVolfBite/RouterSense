def pairwise_oracle(T_L, C_L, T_next, num_gpus):
    """
    Pairwise ILP: 联合优化 Layer L dispatch + combine + Layer L+1 dispatch。
    
    返回 (oracle_makespan, schedule_details)。
    
    G=4 时共 36 chunks:
      - Layer L dispatch: 12 chunks (4*3, 对角线为 0)
      - Layer L combine: 12 chunks
      - Layer L+1 dispatch: 12 chunks
    """
    # 1. 收集所有 chunks，按阶段分组
    # phase 0 = L dispatch, phase 1 = L combine, phase 2 = L+1 dispatch
    chunks = []  # list of (size, src, dst, phase)
    for phase_idx, matrix in enumerate([T_L, C_L, T_next]):
        for i in range(num_gpus):
            for j in range(num_gpus):
                if i != j and matrix[i][j] > 0:
                    chunks.append((matrix[i][j], i, j, phase_idx))
    
