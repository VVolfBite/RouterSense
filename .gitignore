# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and local env files
.venv/
venv/
env/
.env
.env.*

# Model weights and Hugging Face caches
model/
!configs/model/
models/
hf_cache/
!deploy/env/
**/hf_cache/
.cache/
**/.cache/

# Runtime artifacts kept on server but excluded from source-truth closure
artifacts/
outputs/*
!outputs/.gitkeep
archive/*
!archive/.gitkeep
!archive/*/
!archive/*/**

# Experiment outputs and logs
outputs_*/
logs/
*.log

# Local archives and temporary files
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.tmp
tmp/
temp/

# OS/editor noise
.DS_Store
Thumbs.db

# RS runtime artifacts
artifacts/deployment/
outputs/deployment/
deploy/logs/*
!deploy/logs/.gitkeep
model_cache/
*.pid

# RS tracked exceptions
!configs/model/olmoe_1b_7b_instruct.yaml
!configs/topology/
!configs/topology/torchrun_2node_2gpu.yaml
!deploy/inventory/
!deploy/inventory/README.md
!deploy/inventory/hosts.example.yaml
!deploy/inventory/hosts.local.yaml.example
deploy/inventory/hosts.local.yaml
!deploy/scripts/
