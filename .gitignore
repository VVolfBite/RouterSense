!deploy/scripts/*.py
!experiments/prerun/
!experiments/prerun/*.py
!experiments/distributed/
!experiments/distributed/**/*.py
!experiments/ablation/
!experiments/ablation/**/*.yaml
!docs/router_trace_schema.md
!src/routesense/
