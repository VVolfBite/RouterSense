# Experiment outputs and logs
outputs_*/
logs/
*.log

# Local archives and temporary files
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.tmp
tmp/
temp/

# OS/editor noise
.DS_Store
Thumbs.db

