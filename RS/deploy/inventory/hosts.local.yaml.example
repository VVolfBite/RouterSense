cluster_name: rs-2node-ep
nodes:
  - name: node0
    host: NODE0_HOST
    ssh_user: SSH_USER
    node_rank: 0
    current_gpu_count: 2
    target_gpu_count: 2
    paths:
      remote_rs_root: /ABSOLUTE/PATH/TO/RS
      model_cache: /ABSOLUTE/PATH/TO/MODEL_CACHE
      artifact_root: /ABSOLUTE/PATH/TO/ARTIFACTS
  - name: node1
    host: NODE1_HOST
    ssh_user: SSH_USER
    node_rank: 1
    current_gpu_count: 2
    target_gpu_count: 2
    paths:
      remote_rs_root: /ABSOLUTE/PATH/TO/RS
      model_cache: /ABSOLUTE/PATH/TO/MODEL_CACHE
      artifact_root: /ABSOLUTE/PATH/TO/ARTIFACTS
rendezvous:
  master_node: node0
  master_port: 29500
  backend: c10d
